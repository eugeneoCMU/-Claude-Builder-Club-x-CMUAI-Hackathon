# Kintsugi Network - environment variables
# Copy this file to .env and fill in the values.

# --- AI providers (required) ---

# Anthropic (Claude) - content safety + 6-step reasoning + connection analysis
# https://console.anthropic.com/
ANTHROPIC_API_KEY=

# OpenRouter - image generation via Nano Banana (google/gemini-2.5-flash-image-preview)
# https://openrouter.ai/keys
OPENROUTER_API_KEY=

# --- Google Sheets (optional) ---
# If blank, the server falls back to polling data/entries.csv instead.
# Spreadsheet must be shared with the service account's client_email.
GOOGLE_SHEETS_SPREADSHEET_ID=
# base64-encoded service account JSON:
#   cat service-account.json | base64 -w0
GOOGLE_SHEETS_CREDENTIALS_JSON=

# --- Server ---
PORT=3000
POLL_INTERVAL_MS=30000

# --- Storage ---
DB_PATH=./kintsugi.db
SHARDS_DIR=./public/shards

# --- Pipeline ---
MAX_REFLECTION_LENGTH=500
CONTENT_SAFETY_TIMEOUT_MS=3000
MAX_CONNECTIONS_PER_SHARD=3
NEARBY_SHARDS_FOR_ANALYSIS=10

# --- Models (override if needed) ---
ANTHROPIC_MODEL_FAST=claude-haiku-4-5
ANTHROPIC_MODEL_REASONING=claude-sonnet-4-5
OPENROUTER_IMAGE_MODEL=google/gemini-2.5-flash-image-preview
