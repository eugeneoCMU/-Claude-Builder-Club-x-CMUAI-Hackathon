# Copy this to .env.local and fill in your key.
# Get one at https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# Optional: fallback to Haiku for the four "advisor" personas to cut cost
# (Curator always uses Sonnet so the final synthesis stays sharp).
# Set to "true" to enable.
KINTSUGI_USE_HAIKU_FOR_ADVISORS=false
